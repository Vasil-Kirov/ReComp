			dmPrintQuality: i16,
		},
		c: struct {
			dmPosition: POINTL,
			dmDisplayOrientation: DWORD,
			dmDisplayFixedOutput: DWORD,
		},
	},
	dmColor: i16,
	dmDuplex: i16,
	dmYResolution: i16,
	dmTTOption: i16,
	dmCollate: i16,
	dmFormName: [32]BYTE,
	dmLogPixels: WORD,
	dmBitsPerPel: DWORD,
	dmPelsWidth: DWORD,
	dmPelsHeight: DWORD,
	d: union {
		dmDisplayFlags: DWORD,
		dmNup: DWORD,
	},
	dmDisplayFrequency: DWORD,
	dmICMMethod: DWORD,
	dmICMIntent: DWORD,
	dmMediaType: DWORD,
	dmDitherType: DWORD,
	dmReserved1: DWORD,
	dmReserved2: DWORD,
	dmPanningWidth: DWORD,
	dmPanningHeight: DWORD,
}

