module base

Arg :: struct {
    t: type,
    val: *,
}

FileLocation :: struct {
	file: string,
	line: int,
	chr: int,
}

INVALID_TYPE :: (-1) as type;

TypeKind :: enum {
	Invalid ,

	Basic   ,
	Function,
	Struct  ,
	Pointer ,
	Array   ,
	Slice   ,
	Vector  ,
	Enum    ,
	Generic ,
}

BasicKind :: enum {
	Bool,
	String,
	//Cstring,

	U8,
	U16,
	U32,
	U64,

	I8,
	I16,
	I32,
	I64,

	F32,
	F64,

	untypedInteger,
	untypedFloat,

	Int,
	Uint,

	Type,
	Auto,
	Module,
	Error,
}

BasicFlag :: enum: u32{
	Boolean = 0b1,
	Integer = 0b10,
	Float   = 0b100,
	String  = 0b1000,
	//CString = 0b10000,
	Untyped = 0b100000,
	Unsigned= 0b1000000,
	TypeID  = 0b10000000,

	//BasicFlag_Numeric = BasicFlag_Integer | BasicFlag_Float,
}

BasicType :: struct {
    kind: BasicKind,
    flags: u32,
    size: u32,
    name: string,
}

StructFlag :: enum: u32{
	Packed  = 0b1,
	Generic = 0b10,
    Union   = 0b100,
}

StructMember :: struct {
    name: string,
    t: type,
}

StructType :: struct {
    members: []StructMember,
    name: string,
    flags: u32,
}

FunctionType :: struct {
    returns: []type,
    args_t: []type,
}

PointerType :: struct {
    pointee: type,
    is_optional: bool,
}

ArrayType :: struct {
    t: type,
    member_count: u32,
}

SliceType :: struct {
    t: type,
}

EnumMember :: struct {
    name: string,
    value: int,
}

EnumType :: struct {
    name: string,
    members: []EnumMember,
    t: type,
}

VectorKind :: enum {
    Float,
    Int,
    UInt,
}

VectorType :: struct {
    kind: VectorKind,
    elem_count: u32,
}

GenericType :: struct {
    name: string,
}

TypeUnion :: union {
    basic: BasicType,
    struct_: StructType,
    function: FunctionType,
    pointer: PointerType,
    array: ArrayType,
    slice: SliceType,
    enum_: EnumType,
    vector: VectorType,
    generic: GenericType,
}

TypeInfo :: struct {
    kind: TypeKind,
    t: TypeUnion,
}

//type_info :: fn #intr (T: type) -> TypeInfo;

//global_initializers :: fn();

Optional :: struct<T> {
	value: T,
	ok: bool,
};

ok :: fn(value: $t) -> Optional<t> {
	return .{value, true};
}

none :: fn(t: type) -> Optional<t> {
	return .{};
}

unwrap :: fn(opt: Optional<$t>) -> t {
	#assert opt.ok;
	return opt.value;
}

val_or :: fn(opt: Optional<$t>, none: t) -> t {
	if opt.ok {
		return opt.value;
	}
	return none;
}

memcmp :: fn #link="memcmp"(p1: *, p2: *, num: int) -> i32;

main :: fn #link="main.main"() -> i32;

entry :: fn #link="main"() -> i32 {
    res := main();

    return res;
}

type_table: []TypeInfo;

