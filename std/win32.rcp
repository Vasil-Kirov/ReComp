	dwCopyFlags: DWORD,
	pfCancel: ?*BOOL,
	pProgressRoutine: PCOPYFILE2_PROGRESS_ROUTINE,
	pvCallbackContext: PVOID,
	dwCopyFlagsV2: DWORD,
	ioDesiredSize: ULONG,
