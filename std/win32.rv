	FunctionName: PCSTR,
	RedirectionTarget: PVOID,
}

REDIRECTION_FUNCTION_DESCRIPTOR: type: _REDIRECTION_FUNCTION_DESCRIPTOR;

PREDIRECTION_FUNCTION_DESCRIPTOR: type: ?*_REDIRECTION_FUNCTION_DESCRIPTOR;

PCREDIRECTION_FUNCTION_DESCRIPTOR: type: ?*REDIRECTION_FUNCTION_DESCRIPTOR;

_REDIRECTION_DESCRIPTOR :: struct  {
	Version: ULONG,
	FunctionCount: ULONG,
	Redirections: PCREDIRECTION_FUNCTION_DESCRIPTOR,
}

REDIRECTION_DESCRIPTOR: type: _REDIRECTION_DESCRIPTOR;

PREDIRECTION_DESCRIPTOR: type: ?*_REDIRECTION_DESCRIPTOR;

PCREDIRECTION_DESCRIPTOR: type: ?*REDIRECTION_DESCRIPTOR;

