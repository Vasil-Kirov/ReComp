module build


compile :: fn(out: *CompileInfo) {
	to_fill := *out;

	to_fill.files[0] = c"../arrays.rv";
	to_fill.files[1] = c"../basic.rv";
	to_fill.files[2] = c"../fn_call.rv";
	to_fill.files[3] = c"../fn_ptr.rv";
	to_fill.files[4] = c"../pointers.rv";
	to_fill.files[5] = c"../struct.rv";
	to_fill.files[6] = c"../pass_struct.rv";
	to_fill.files[7] = c"../struct_in_struct.rv";

	to_fill.file_count = 8;

	*out = to_fill;
}




