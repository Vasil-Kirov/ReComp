DRIVERPROC: type: ?*fn(a: DWORD_PTR, b: HDRVR, c: UINT, d: LPARAM, e: LPARAM) -> LRESULT #foreign;

CloseDriver :: fn(
	hDriver: HDRVR,
	lParam1: LPARAM,
	lParam2: LPARAM
) -> LRESULT #cc="cdecl" #foreign #link="CloseDriver";

OpenDriver :: fn(
	szDriverName: LPCWSTR,
	szSectionName: LPCWSTR,
	lParam2: LPARAM
) -> HDRVR #cc="cdecl" #foreign #link="OpenDriver";

SendDriverMessage :: fn(
	hDriver: HDRVR,
	message: UINT,
	lParam1: LPARAM,
	lParam2: LPARAM
) -> LRESULT #cc="cdecl" #foreign #link="SendDriverMessage";

DrvGetModuleHandle :: fn(
	hDriver: HDRVR
) -> HMODULE #cc="cdecl" #foreign #link="DrvGetModuleHandle";

GetDriverModuleHandle :: fn(
	hDriver: HDRVR
) -> HMODULE #cc="cdecl" #foreign #link="GetDriverModuleHandle";

DefDriverProc :: fn(
	dwDriverIdentifier: DWORD_PTR,
	hdrvr: HDRVR,
	uMsg: UINT,
	lParam1: LPARAM,
	lParam2: LPARAM
) -> LRESULT #cc="cdecl" #foreign #link="DefDriverProc";

DriverCallback :: fn(
	dwCallback: DWORD_PTR,
	dwFlags: DWORD,
	hDevice: HDRVR,
	dwMsg: DWORD,
	dwUser: DWORD_PTR,
	dwParam1: DWORD_PTR,
	dwParam2: DWORD_PTR
) -> BOOL #cc="cdecl" #foreign #link="DriverCallback";

sndOpenSound :: fn(
	EventName: LPCWSTR,
	AppName: LPCWSTR,
	Flags: INT32,
	FileHandle: PHANDLE
) -> LONG #cc="cdecl" #foreign #link="sndOpenSound";

DRIVERMSGPROC: type: ?*fn(a: DWORD, b: DWORD, c: DWORD_PTR, d: DWORD_PTR, e: DWORD_PTR) -> DWORD #foreign;

mmDrvInstall :: fn(
	hDriver: HDRVR,
	wszDrvEntry: LPCWSTR,
	drvMessage: DRIVERMSGPROC,
	wFlags: UINT
) -> UINT #cc="cdecl" #foreign #link="mmDrvInstall";

