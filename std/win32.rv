module win32;

FD_SET :: fn(fd: SOCKET, set: *fd_set) #inline {
    if set.fd_count < FD_SETSIZE as u_int
        set.fd_array[set.fd_count++]=fd;
}

FD_ZERO :: fn(set: *fd_set) #inline {
	set.fd_count=0;
}

// Depends on ws2_32
//FD_ISSET :: fn(fd: SOCKET, set: *fd_set) -> i32 #inline {
//	return __WSAFDIsSet(fd, set);
//}

FD_CLR :: fn(fd: SOCKET, set: *fd_set) #inline {
    for __i: u_int = 0; __i < set.fd_count; __i++ {
        if set.fd_array[__i] == fd {
            for __i < set.fd_count-1 {
                set.fd_array[__i] = set.fd_array[__i+1];
                __i++;
            }
            set.fd_count--;
            break;
        }
    }
}


