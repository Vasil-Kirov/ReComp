mciGetDriverData :: fn(
	wDeviceID: MCIDEVICEID
) -> DWORD_PTR #cc="cdecl" #foreign #link="mciGetDriverData";

mciLoadCommandResource :: fn(
	hInstance: HANDLE,
	lpResName: LPCWSTR,
	wType: UINT
) -> UINT #cc="cdecl" #foreign #link="mciLoadCommandResource";

mciSetDriverData :: fn(
	wDeviceID: MCIDEVICEID,
	dwData: DWORD_PTR
) -> BOOL #cc="cdecl" #foreign #link="mciSetDriverData";

mciDriverYield :: fn(
	wDeviceID: MCIDEVICEID
) -> UINT #cc="cdecl" #foreign #link="mciDriverYield";

mciDriverNotify :: fn(
	hwndCallback: HANDLE,
	wDeviceID: MCIDEVICEID,
	uStatus: UINT
) -> BOOL #cc="cdecl" #foreign #link="mciDriverNotify";

mciFreeCommandResource :: fn(
	wTable: UINT
) -> BOOL #cc="cdecl" #foreign #link="mciFreeCommandResource";

